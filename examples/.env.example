# ============================================
# Variables d'environnement pour playwright-xray-advanced-reporter
# ============================================
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER le fichier .env !

# ============================================
# JIRA Cloud
# ============================================

# URL de votre instance JIRA Cloud
JIRA_BASE_URL=https://votre-instance.atlassian.net

# Email du compte JIRA
JIRA_EMAIL=votre.email@company.com

# API Token JIRA
# Créer sur : https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=votre_token_jira_ici

# Clé du projet JIRA (préfixe des issues)
JIRA_PROJECT_KEY=PROJ

# ============================================
# Xray Cloud
# ============================================

# Client ID et Secret Xray
# Créer sur : https://xray.cloud.getxray.app/settings/api-keys
XRAY_CLIENT_ID=votre_client_id_xray
XRAY_CLIENT_SECRET=votre_client_secret_xray

# Clé du Test Plan (optionnel)
XRAY_TEST_PLAN_KEY=PROJ-123

# ============================================
# Application testée
# ============================================

# URL de base de l'application
BASE_URL=http://localhost:3000

# Environnement de test
TEST_ENV=Staging

# ============================================
# Debug
# ============================================

# Activer les logs détaillés
DEBUG=false
